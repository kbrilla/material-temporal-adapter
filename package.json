{
  "name": "@kbrilla/temporal-adapter-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "test:cov": "pnpm -r --filter './packages/*' test:cov",
    "lint": "pnpm -r lint",
    "demo": "pnpm --filter demo storybook",
    "demo:build": "pnpm --filter demo build-storybook",
    "demo:e2e": "pnpm --filter demo test:e2e",
    "format": "prettier --write \"**/*.{ts,html,md,json}\"",
    "release": "changeset publish"
  },
  "pnpm": {
    "overrides": {
      "@angular/core": "19.2.22",
      "@angular/common": "19.2.22",
      "@angular/compiler": "19.2.22",
      "@angular/compiler-cli": "19.2.22",
      "@angular/platform-browser": "19.2.22",
      "@angular/platform-browser-dynamic": "19.2.22",
      "@angular/forms": "19.2.22",
      "@angular/cdk": "19.2.19",
      "@angular/material": "19.2.19"
    }
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.2",
    "@analogjs/vitest-angular": "^2.5.2",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular/cdk": "19.2.19",
    "@angular/common": "19.2.22",
    "@angular/compiler": "19.2.22",
    "@angular/compiler-cli": "19.2.22",
    "@angular/core": "19.2.22",
    "@angular/forms": "19.2.22",
    "@angular/material": "19.2.19",
    "@angular/platform-browser": "19.2.22",
    "@angular/platform-browser-dynamic": "19.2.22",
    "@changesets/cli": "^2.27.0",
    "@js-temporal/polyfill": "^0.5.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.0",
    "expect-type": "^1.3.0",
    "jsdom": "^29.1.1",
    "ng-packagr": "~19",
    "prettier": "^3.3.0",
    "rxjs": "^7.8.2",
    "temporal-polyfill": "^0.3.2",
    "tslib": "^2.8.1",
    "typescript": "~5.5.4",
    "vitest": "^2",
    "zone.js": "~0.15.0"
  }
}
